<Window x:Class="WordPictureAddIn.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="图片预览"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowState="Maximized"
        Background="#D1000000"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        MouseWheel="Window_MouseWheel"
        MouseMove="Window_MouseMove">
    <Window.Resources>
        <Style x:Key="ToolToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF1F4"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EEF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Button x:Name="CloseButton"
                Panel.ZIndex="10"
                Width="42"
                Height="34"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0"
                Click="CloseButton_Click"
                BorderThickness="0"
                FontFamily="Microsoft YaHei UI"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White"
                Cursor="Hand"
                Content="×">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder" Background="#303030" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#C44646"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#9F3030"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Canvas x:Name="ImageCanvas"
                Panel.ZIndex="0"
                ClipToBounds="True"
                Background="Transparent"
                Cursor="None">
            <Canvas x:Name="ContentCanvas"
                    RenderTransformOrigin="0,0"
                    MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                    MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                    MouseMove="PreviewImage_MouseMove"
                    MouseWheel="PreviewImage_MouseWheel">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ContentScaleTransform" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ContentTranslateTransform" X="0" Y="0"/>
                    </TransformGroup>
                </Canvas.RenderTransform>
                <Image x:Name="PreviewImage"
                       Stretch="Fill"/>
                <Canvas x:Name="AnnotationCanvas"
                        Panel.ZIndex="5"
                        Background="Transparent"
                        IsHitTestVisible="False"
                        MouseLeftButtonDown="AnnotationCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="AnnotationCanvas_MouseLeftButtonUp"
                        MouseMove="AnnotationCanvas_MouseMove"/>
            </Canvas>
        </Canvas>

        <Border x:Name="ToolbarPanel"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,0"
                Padding="14,10"
                CornerRadius="18"
                Background="#FAFFFFFF"
                BorderBrush="#E7EAF0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ToggleButton x:Name="LineToolButton"
                                  Style="{StaticResource ToolToggleStyle}"
                                  Click="ToolButton_Click"
                                  Tag="Line"
                                  ToolTip="直线">
                        <Grid Width="22" Height="18">
                            <Path Stroke="#4B5563" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M1,9 L21,9"/>
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="RectangleToolButton"
                                  Style="{StaticResource ToolToggleStyle}"
                                  Click="ToolButton_Click"
                                  Tag="Rectangle"
                                  ToolTip="矩形">
                        <Rectangle Width="22" Height="15" Stroke="#4B5563" StrokeThickness="2.5" RadiusX="2" RadiusY="2"/>
                    </ToggleButton>
                    <ToggleButton x:Name="EllipseToolButton"
                                  Style="{StaticResource ToolToggleStyle}"
                                  Click="ToolButton_Click"
                                  Tag="Ellipse"
                                  ToolTip="圆形">
                        <Ellipse Width="22" Height="22" Stroke="#4B5563" StrokeThickness="2.5"/>
                    </ToggleButton>
                    <ToggleButton x:Name="ArrowToolButton"
                                  Style="{StaticResource ToolToggleStyle}"
                                  Click="ToolButton_Click"
                                  Tag="Arrow"
                                  ToolTip="箭头">
                        <Grid Width="22" Height="26">
                            <Path Stroke="#4B5563" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M11,22 L11,6"/>
                            <Path Stroke="#4B5563" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M5,12 L11,6 L17,12"/>
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="TextToolButton"
                                  Style="{StaticResource ToolToggleStyle}"
                                  Click="ToolButton_Click"
                                  Tag="Text"
                                  ToolTip="文字">
                        <TextBlock Text="T"
                                   FontFamily="Microsoft YaHei UI"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#4B5563"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </ToggleButton>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="1"
                        Height="24"
                        Margin="11,0,11,0"
                        VerticalAlignment="Center"
                        Background="#E1E4E8"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="UndoButton"
                            Width="46"
                            Height="38"
                            Margin="2,0"
                            Click="UndoButton_Click"
                            ToolTip="撤销"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ButtonBorder" Background="Transparent" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF1F4"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EEF9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="24" Height="22">
                            <Path Stroke="#4B5563"
                                  StrokeThickness="2.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M19,7 C16,4 11,4 8,7 C5,10 5,14 8,17 C10,19 14,19 17,17"
                                  RenderTransformOrigin="0.5,0.5"
                                  Margin="4,6,6,1"
                                  Stretch="Fill">
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="210.09"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>
                            <Path Stroke="#4B5563"
                                  StrokeThickness="2.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M10,5 L6,7 L10,10"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="12.609"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                    </Button>

                    <Button x:Name="ResetZoomButton"
                            Width="46"
                            Height="38"
                            Margin="2,0"
                            Click="ResetZoomButton_Click"
                            ToolTip="恢复原比例"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ButtonBorder" Background="Transparent" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF1F4"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EEF9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="22" Height="22">
                            <Rectangle Width="18" Height="14" Stroke="#4B5563" StrokeThickness="2" RadiusX="2" RadiusY="2"/>
                            <Path Stroke="#4B5563" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M16,4 L20,4 L20,8"/>
                            <Path Stroke="#4B5563" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M6,18 L2,18 L2,14"/>
                        </Grid>
                    </Button>

                    <Button x:Name="SaveButton"
                            Width="46"
                            Height="38"
                            Margin="2,0"
                            Click="SaveButton_Click"
                            ToolTip="保存"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ButtonBorder" Background="Transparent" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF1F4"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EEF9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="22" Height="22">
                            <Rectangle Width="18" Height="18" Stroke="#4B5563" StrokeThickness="2" RadiusX="2" RadiusY="2"/>
                            <Rectangle Width="10" Height="5" Fill="#4B5563" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <Rectangle Width="8" Height="5" Stroke="#4B5563" StrokeThickness="1.6" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Canvas x:Name="CursorOverlay"
                Panel.ZIndex="30"
                IsHitTestVisible="False">
            <Grid x:Name="HandCursorVisual" Width="20" Height="20" Visibility="Collapsed">
                <Viewbox Stretch="Uniform">
                    <Path Fill="#333333"
                          Stroke="#333333"
                          StrokeThickness="42"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
