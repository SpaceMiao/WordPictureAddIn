0-30.703-30.968 111.077 111.077 0 0 0-84.981-17.06 113.203 113.203 0 0 0-103.694-67.656z"/>
                </Viewbox>
            </Grid>
            <Grid x:Name="PenCursorVisual" Width="20" Height="20" Visibility="Collapsed">
                <Viewbox Stretch="Uniform">
                    <Canvas Width="1024" Height="1024" RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <RotateTransform Angle="90"/>
                        </Canvas.RenderTransform>
                        <Path Fill="#FFFFFF" Data="M597.333333 273.664L657.664 213.333333l195.84 195.669334L793.258667 469.333333z"/>
                        <Path Fill="#FFFFFF" Data="M745.472 203.264L281.898667 666.837333l-39.253334 157.226667 157.184-39.296L863.402667 321.194667l-117.930667-117.930667zM981.333333 321.194667l-538.88 538.88L128 938.666667l78.634667-314.453334L745.472 85.333333 981.333333 321.194667z"/>
                        <Path Stroke="#2E2F30" StrokeThickness="42" Fill="Transparent" Data="M597.333333 273.664L657.664 213.333333l195.84 195.669334L793.258667 469.333333z"/>
                        <Path Stroke="#2E2F30" StrokeThickness="42" Fill="Transparent" Data="M745.472 203.264L281.898667 666.837333l-39.253334 157.226667 157.184-39.296L863.402667 321.194667l-117.930667-117.930667zM981.333333 321.194667l-538.88 538.88L128 938.666667l78.634667-314.453334L745.472 85.333333 981.333333 321.194667z"/>
                    </Canvas>
                </Viewbox>
            </Grid>
        </Canvas>

    </Grid>
</Window>
